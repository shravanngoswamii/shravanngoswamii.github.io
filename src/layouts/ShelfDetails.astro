---
import { type CollectionEntry, render } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import ClimbingBackToTop from "@components/ClimbingBackToTop.astro";
import TableOfContents from "@components/TableOfContents.astro";
import ShareLinks from "@components/ShareLinks.astro";
import Giscus from "@components/Giscus.astro";
import {
  getCoverGradient,
  optimizePosterUrl,
  SHELF_STATUS,
  SHELF_TYPE,
  stripExt,
} from "@utils/shelf";
import { SITE } from "@config";
import { TbChevronLeft, TbChevronRight } from "react-icons/tb";
import {
  getAllPosts,
  COLLECTION_META,
  getPostSlug,
  getPostTopic,
} from "@utils/collections";
import getSortedPosts from "@utils/getSortedPosts";
import { withBase } from "@utils/base";
import { formatYear } from "@utils/formatYear";
import Tabs from "@components/Tabs.astro";
import TabItem from "@components/TabItem.astro";
import Callout from "@components/mdx/Callout";
import QuoteBlock from "@components/mdx/QuoteBlock";
import Spoiler from "@components/mdx/Spoiler";
import Timeline from "@components/mdx/Timeline";
import Comparison, { ComparisonSide } from "@components/mdx/Comparison";
import Progress from "@components/mdx/Progress";

export interface Props {
  entry: CollectionEntry<"shelf">;
  items: CollectionEntry<"shelf">[];
  index: number;
}

const { entry, items, index } = Astro.props;
const { data } = entry;
const { Content, headings } = await render(entry);
const gradient = getCoverGradient(data.title);
const optimizedPoster = optimizePosterUrl(data.poster, 420);
const statusInfo = SHELF_STATUS[data.status];
const typeInfo = SHELF_TYPE[data.type];
const hasContent = entry.body && entry.body.trim().length > 0;
const toc = headings.filter((h) => h.depth > 1 && h.depth < 4);
const hasToc = toc.length > 0;

const isBook = data.type === "book";
const isFilm = ["movie", "documentary", "miniseries"].includes(data.type);
const isSeries = ["series", "sitcom"].includes(data.type);
const isAnime = data.type === "anime";
const isGame = data.type === "game";

const prevItem = index > 0 ? items[index - 1] : null;
const nextItem = index < items.length - 1 ? items[index + 1] : null;

const allPosts = getSortedPosts(await getAllPosts());
let readMorePostsRaw = allPosts
  .filter(
    (p) =>
      p.data.tags.some((t) => data.tags.includes(t)) ||
      data.categories.includes(p.data.topic),
  )
  .slice(0, 4);

if (readMorePostsRaw.length === 0) {
  readMorePostsRaw = allPosts.slice(0, 4);
}

const readMorePosts = readMorePostsRaw.map((p) => ({
  title: p.data.title,
  slug: getPostSlug(p),
  topic: getPostTopic(p),
}));
const headerColorVar =
  data.categories && data.categories[0]
    ? `--color-collection-${data.categories[0]}`
    : "--color-text-base";
const showFilmLinks = isFilm || isAnime || isSeries;

const ogUrl = new URL(
  withBase(`/shelf/${stripExt(entry.id)}/og.png`),
  Astro.url.origin,
).href;
---

<Layout
  title={`${data.title} | ${SITE.title}`}
  description={data.description}
  ogImage={ogUrl}
  scrollSmooth
>
  <Header />

  <div
    class="relative border-b border-skin-line/10"
    style={`background: linear-gradient(135deg, rgba(var(${headerColorVar}), 0.08) 0%, transparent 60%)`}
  >
    <div
      class="absolute inset-0 opacity-[0.03] pointer-events-none"
      style={`background-image: repeating-linear-gradient(90deg, transparent, transparent 40px, rgba(var(${headerColorVar}), 0.5) 40px, rgba(var(${headerColorVar}), 0.5) 41px); background-size: 41px 100%;`}
    >
    </div>
    <div
      class="mx-auto w-full max-w-7xl px-4 pt-36 sm:pt-32 pb-10 relative z-10"
    >
      <div class="max-w-3xl mx-auto">
        <div
          class="flex flex-col items-center sm:items-start sm:flex-row gap-8"
        >
          <div class="w-32 sm:w-40 shrink-0 group/flip">
            <div
              class="relative w-full aspect-2/3"
              style="perspective: 800px; -webkit-perspective: 800px;"
            >
              <div
                class="shelf-details-flip-inner relative w-full h-full transition-transform duration-500"
                style="transform-style: preserve-3d; -webkit-transform-style: preserve-3d;"
              >
                {/* FRONT - Poster (or gradient fallback) */}
                <div
                  class="absolute inset-0 rounded overflow-hidden shadow-lg"
                  style="backface-visibility: hidden; -webkit-backface-visibility: hidden; transform: rotateY(0deg); -webkit-transform: rotateY(0deg);"
                >
                  <div
                    class="absolute inset-0"
                    style={`background: ${gradient}`}
                  >
                    <div
                      class="absolute inset-0 pointer-events-none"
                      style="background: radial-gradient(ellipse at 25% 15%, rgba(255,255,255,0.12) 0%, transparent 50%);"
                    >
                    </div>
                  </div>
                  {
                    optimizedPoster && (
                      <img
                        src={optimizedPoster}
                        alt={`${data.title} poster`}
                        class="absolute inset-0 w-full h-full object-cover"
                        loading="lazy"
                        decoding="async"
                      />
                    )
                  }
                  <div
                    class="absolute inset-0 bg-linear-to-t from-black/60 via-transparent to-black/20"
                  >
                  </div>
                  <div class="absolute top-2 left-2 z-10">
                    <span
                      class="w-3 h-3 select-none text-white/60 leading-none shelf-icon"
                      set:html={typeInfo.icon}
                    />
                  </div>
                  <div class="absolute bottom-0 inset-x-0 z-10 px-3 pb-3">
                    <h2
                      class="text-white font-serif text-xs sm:text-sm leading-snug drop-shadow-md"
                    >
                      {data.title}
                    </h2>
                    <p
                      class="font-serif text-white/60 text-[10px] italic mt-0.5"
                    >
                      {data.creator}
                    </p>
                  </div>
                </div>

                {/* BACK - Gradient cover */}
                <div
                  class="absolute inset-0 rounded overflow-hidden shadow-lg"
                  style={`backface-visibility: hidden; -webkit-backface-visibility: hidden; transform: rotateY(180deg); -webkit-transform: rotateY(180deg); background: ${gradient};`}
                >
                  <div
                    class="absolute inset-0 pointer-events-none"
                    style="background: radial-gradient(ellipse at 25% 15%, rgba(255,255,255,0.12) 0%, transparent 50%);"
                  >
                  </div>
                  {
                    isBook && (
                      <>
                        <div class="absolute left-0 inset-y-0 w-0.75 bg-black/25" />
                        <div class="absolute left-0.75 inset-y-0 w-px bg-white/10" />
                      </>
                    )
                  }
                  {
                    isFilm && (
                      <div
                        class="absolute inset-0 pointer-events-none opacity-[0.06]"
                        style="background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(255,255,255,0.3) 3px, rgba(255,255,255,0.3) 4px);"
                      />
                    )
                  }
                  {
                    isSeries && (
                      <div
                        class="absolute inset-0 pointer-events-none opacity-[0.04]"
                        style="background: repeating-linear-gradient(90deg, transparent, transparent 8px, rgba(255,255,255,0.2) 8px, rgba(255,255,255,0.2) 9px);"
                      />
                    )
                  }
                  {
                    isAnime && (
                      <div
                        class="absolute inset-0 pointer-events-none opacity-[0.05]"
                        style="background: repeating-linear-gradient(45deg, transparent, transparent 5px, rgba(255,255,255,0.4) 5px, rgba(255,255,255,0.4) 6px);"
                      />
                    )
                  }
                  {
                    isGame && (
                      <div
                        class="absolute inset-0 pointer-events-none opacity-[0.06]"
                        style="background-image: url('data:image/svg+xml,%3Csvg width=%226%22 height=%226%22 viewBox=%220 0 6 6%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Crect width=%223%22 height=%223%22 fill=%22%23ffffff%22/%3E%3C/svg%3E'); background-size: 6px 6px;"
                      />
                    )
                  }
                  <div
                    class="absolute inset-0 pointer-events-none opacity-[0.03]"
                    style="background-image: url('data:image/svg+xml,%3Csvg width=%224%22 height=%224%22 viewBox=%220 0 4 4%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cpath d=%22M1 3h1v1H1V3zm2-2h1v1H3V1z%22 fill=%22%23ffffff%22 fill-opacity=%221%22/%3E%3C/svg%3E');"
                  >
                  </div>
                  <div
                    class="absolute inset-0 flex flex-col items-center justify-center px-3 text-center z-10"
                  >
                    <h2
                      class="text-white font-serif text-xs sm:text-sm leading-snug drop-shadow-sm"
                    >
                      {data.title}
                    </h2>
                  </div>
                  <div
                    class="absolute bottom-0 inset-x-0 z-10 bg-linear-to-t from-black/60 via-black/20 to-transparent pt-8"
                  >
                    <div class="text-center pb-2 px-2">
                      <p class="font-serif text-white/55 text-[10px] italic">
                        {data.creator}
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="flex-1 min-w-0 text-center sm:text-left">
            <div
              class="flex flex-wrap items-center justify-center sm:justify-start gap-2 mb-4"
            >
              <span
                class="px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider rounded-sm bg-skin-card-muted text-skin-base/60"
              >
                {typeInfo.label}
              </span>
              {
                data.categories.map((cat) => (
                  <span
                    class="px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider rounded-sm"
                    style={`background: rgba(var(--color-collection-${cat}), 0.1); color: rgb(var(--color-collection-${cat}))`}
                  >
                    {cat}
                  </span>
                ))
              }
            </div>

            <h1
              class="font-serif text-3xl sm:text-4xl text-skin-base leading-tight mb-2"
            >
              {data.title}
            </h1>
            <p class="font-serif text-sm italic text-skin-base/50 mb-5">
              {data.creator}
            </p>

            <div
              class="flex flex-wrap items-center justify-center sm:justify-start gap-x-8 gap-y-3 py-4 border-t border-skin-line/15"
            >
              {
                data.rating !== undefined && (
                  <div class="flex flex-col">
                    <span class="font-mono text-[9px] uppercase tracking-widest text-skin-base/35 mb-0.5">
                      Rating
                    </span>
                    <div class="flex items-baseline gap-1">
                      <span class="text-2xl font-serif font-medium text-skin-accent">
                        {data.rating}
                      </span>
                      <span class="text-sm text-skin-base/30 font-mono">
                        /10
                      </span>
                    </div>
                  </div>
                )
              }
              <div class="flex flex-col">
                <span
                  class="font-mono text-[9px] uppercase tracking-widest text-skin-base/35 mb-0.5"
                  >Status</span
                >
                <span
                  class="px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider rounded-sm w-fit"
                  style={`background: ${statusInfo.color}20; color: ${statusInfo.color}`}
                >
                  {statusInfo.label}
                </span>
              </div>
              {
                data.year && (
                  <div class="flex flex-col">
                    <span class="font-mono text-[9px] uppercase tracking-widest text-skin-base/35 mb-0.5">
                      Year
                    </span>
                    <span class="font-mono text-sm text-skin-base/70">
                      {formatYear(data.year)}
                    </span>
                  </div>
                )
              }
              {
                data.genre && (
                  <div class="flex flex-col">
                    <span class="font-mono text-[9px] uppercase tracking-widest text-skin-base/35 mb-0.5">
                      Genre
                    </span>
                    <span class="font-serif text-sm italic text-skin-base/60">
                      {data.genre}
                    </span>
                  </div>
                )
              }
            </div>

            {
              showFilmLinks && (
                <div class="flex items-center justify-center sm:justify-start gap-3 mt-3">
                  {data.imdbId && (
                    <a
                      href={`https://www.imdb.com/title/${data.imdbId}/`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1.5 text-[10px] font-mono uppercase tracking-widest text-skin-base/40 hover:text-skin-base/70 transition-colors"
                      title="IMDb"
                    >
                      <img
                        src={withBase("/assets/imdb.png")}
                        alt="IMDb"
                        class="w-4 h-4 object-contain"
                      />
                      <span>IMDb</span>
                    </a>
                  )}
                  {data.letterboxdSlug && (
                    <a
                      href={`https://letterboxd.com/film/${data.letterboxdSlug}/`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1.5 text-[10px] font-mono uppercase tracking-widest text-skin-base/40 hover:text-skin-base/70 transition-colors"
                      title="Letterboxd"
                    >
                      <img
                        src="https://a.ltrbxd.com/logos/letterboxd-decal-dots-pos-rgb-500px.png"
                        alt="Letterboxd"
                        class="w-4 h-4 object-contain dark:hidden"
                      />
                      <img
                        src="https://a.ltrbxd.com/logos/letterboxd-decal-dots-neg-rgb-500px.png"
                        alt="Letterboxd"
                        class="w-4 h-4 object-contain hidden dark:inline"
                      />
                      <span>Letterboxd</span>
                    </a>
                  )}
                  {!data.imdbId && !data.letterboxdSlug && (
                    <>
                      <a
                        href="https://www.imdb.com/user/ur213092538/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1.5 text-[10px] font-mono uppercase tracking-widest text-skin-base/40 hover:text-skin-base/70 transition-colors"
                        title="IMDb Profile"
                      >
                        <img
                          src={withBase("/assets/imdb.png")}
                          alt="IMDb"
                          class="w-4 h-4 object-contain"
                        />
                        <span>IMDb</span>
                      </a>
                      <a
                        href="https://letterboxd.com/shravangoswami/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1.5 text-[10px] font-mono uppercase tracking-widest text-skin-base/40 hover:text-skin-base/70 transition-colors"
                        title="Letterboxd"
                      >
                        <img
                          src="https://a.ltrbxd.com/logos/letterboxd-decal-dots-pos-rgb-500px.png"
                          alt="Letterboxd"
                          class="w-4 h-4 object-contain dark:hidden"
                        />
                        <img
                          src="https://a.ltrbxd.com/logos/letterboxd-decal-dots-neg-rgb-500px.png"
                          alt="Letterboxd"
                          class="w-4 h-4 object-contain hidden dark:inline"
                        />
                        <span>Letterboxd</span>
                      </a>
                    </>
                  )}
                </div>
              )
            }

            {
              data.description && (
                <p class="text-sm text-skin-base/60 leading-relaxed mt-3">
                  {data.description}
                </p>
              )
            }
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto w-full max-w-7xl px-4 lg:max-w-none lg:px-0">
    <div
      class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_minmax(auto,48rem)_minmax(0,1fr)] gap-8"
    >
      <aside class="hidden lg:flex lg:justify-center">
        <div
          class="relative mt-8 flex w-70 flex-col items-center"
          id="left-sidebar"
        >
          <div id="sidebar-quotes" class="w-full"></div>
          {
            readMorePosts.length > 0 && (
              <div
                id="sidebar-readmore"
                class="w-full max-w-45"
                style="margin-top: 40vh;"
              >
                <span class="block font-mono text-[9px] uppercase tracking-widest text-skin-base/30 mb-3">
                  From the Same Shelf
                </span>
                <div class="flex flex-col gap-3">
                  {readMorePosts.map((p) => (
                    <a
                      href={withBase(
                        `${COLLECTION_META[p.topic as keyof typeof COLLECTION_META]?.prefix || "/blog"}/${p.slug}`,
                      )}
                      class="group block"
                    >
                      <div class="flex items-start gap-2">
                        <span
                          class="w-1 h-1 rounded-full mt-1.5 shrink-0"
                          style={`background: rgb(var(--color-collection-${p.topic}))`}
                        />
                        <span class="text-xs text-skin-base/50 group-hover:text-skin-base transition-colors leading-snug line-clamp-2">
                          {p.title}
                        </span>
                      </div>
                    </a>
                  ))}
                </div>
                <a
                  href={withBase("/shelf")}
                  class="group flex items-center gap-1.5 mt-4 font-mono text-[9px] uppercase tracking-widest text-skin-base/25 hover:text-skin-accent transition-colors"
                >
                  <span>See All</span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="10"
                    height="10"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <path d="M5 12h14" />
                      <path d="m12 5 7 7-7 7" />
                    </>
                  </svg>
                </a>
              </div>
            )
          }
        </div>
      </aside>

      <div class="flex flex-col">
        <main id="main-content">
          {
            hasToc && (
              <TableOfContents headings={headings} mobile={true} open={true} />
            )
          }

          {
            hasContent && (
              <article id="article" class="prose mx-auto mt-8 max-w-3xl">
                <Content
                  components={{
                    Tabs,
                    TabItem,
                    Callout,
                    QuoteBlock,
                    Spoiler,
                    Timeline,
                    Comparison,
                    ComparisonSide,
                    Progress,
                  }}
                />
              </article>
            )
          }

          {
            !hasContent && (
              <div class="mx-auto mt-12 max-w-3xl text-center py-16">
                <p class="text-skin-base/30 font-mono text-sm">
                  No notes yet - check back later.
                </p>
              </div>
            )
          }

          <div class="flex items-center justify-center mt-8">
            <ShareLinks />
          </div>

          <hr class="my-6 border-dashed" />

          <Giscus />

          <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2">
            {
              prevItem && (
                <a
                  href={withBase(`/shelf/${stripExt(prevItem.id)}/`)}
                  class="flex w-full gap-1 hover:opacity-75 items-center"
                >
                  <TbChevronLeft className="h-6 w-6 flex-none" />
                  <div>
                    <span>Previous</span>
                    <div class="text-sm text-skin-accent/85">
                      {prevItem.data.title}
                    </div>
                  </div>
                </a>
              )
            }
            {
              nextItem && (
                <a
                  href={withBase(`/shelf/${stripExt(nextItem.id)}/`)}
                  class="flex w-full justify-end gap-1 text-right hover:opacity-75 sm:col-start-2 items-center"
                >
                  <div>
                    <span>Next</span>
                    <div class="text-sm text-skin-accent/85">
                      {nextItem.data.title}
                    </div>
                  </div>
                  <TbChevronRight className="h-6 w-6 flex-none" />
                </a>
              )
            }
          </div>
        </main>
      </div>

      <aside class="hidden lg:block relative mt-8">
        {
          hasToc && (
            <div class="sticky top-24 transition-opacity duration-300">
              <TableOfContents headings={headings} />
            </div>
          )
        }
      </aside>
    </div>
  </div>

  <ClimbingBackToTop />
  <Footer />
</Layout>

<style>
  @reference "../styles/base.css";
  main {
    @apply mx-auto w-full max-w-3xl pb-12;
  }

  @media (min-width: 1024px) {
    main {
      @apply mx-0;
    }

    :global(figure.not-prose[data-position="left"]),
    :global(div.not-prose[data-position="left"]) {
      height: 0 !important;
      overflow: hidden !important;
      margin: 0 !important;
      padding: 0 !important;
      border: 0 !important;
      opacity: 0 !important;
      visibility: hidden !important;
    }
  }

  :global(pre) {
    @apply rounded-lg border border-skin-line/20 overflow-x-auto;
    line-height: 1.5 !important;
    font-size: 0.875rem !important;
    padding: 1rem !important;
  }

  :global(pre code) {
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
      "Courier New", monospace !important;
    font-size: 0.875rem !important;
    line-height: 1.5 !important;
    display: block;
  }

  :global(.astro-code),
  :global(.astro-code span) {
    color: var(--shiki-light);
    background-color: transparent !important;
  }

  :global(html[data-theme="dark"] .astro-code),
  :global(html[data-theme="dark"] .astro-code span) {
    color: var(--shiki-dark);
    background-color: transparent !important;
  }

  :global(pre) {
    background-color: rgba(var(--color-card), 0.6) !important;
    backdrop-filter: blur(12px);
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.1),
      0 2px 4px -1px rgba(0, 0, 0, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
    transition: all 0.3s ease;
  }

  :global(pre:hover) {
    box-shadow:
      0 10px 15px -3px rgba(0, 0, 0, 0.1),
      0 4px 6px -2px rgba(0, 0, 0, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
    border-color: rgba(var(--color-border), 0.6);
  }

  :global(.copy-code) {
    @apply absolute right-2 top-2 z-20 p-1.5 opacity-0 transition-all scale-95 cursor-pointer;
    color: rgba(var(--color-text-base), 0.4);
  }
  :global(.code-wrapper:hover .copy-code) {
    @apply opacity-100 scale-100;
  }
  :global(.copy-code:hover) {
    color: rgba(var(--color-accent), 1);
    filter: drop-shadow(0 0 4px rgba(var(--color-accent), 0.3));
  }

  :global(.line-numbers) {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 2rem;
    padding-top: 1rem;
    padding-bottom: 1rem;
    text-align: right;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
      "Courier New", monospace !important;
    font-size: 0.875rem !important;
    line-height: 1.5 !important;
    color: rgba(var(--color-text-base), 0.25);
    user-select: none;
    pointer-events: none;
    overflow: hidden;
  }

  :global(pre) {
    padding-left: 2rem !important;
    padding-right: 1rem !important;
    padding-top: 1rem !important;
    padding-bottom: 1rem !important;
  }

  :global(.line-numbers span) {
    display: block;
    padding-right: 0.75rem;
    height: 1.3125rem;
  }

  .group\/flip:hover .shelf-details-flip-inner {
    transform: rotateY(180deg);
    -webkit-transform: rotateY(180deg);
  }
</style>

<script is:inline data-astro-rerun>
  (() => {
  function createProgressBar() {
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-skin-fill";
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-skin-accent";
    progressBar.id = "myBar";
    progressContainer.appendChild(progressBar);
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      const myBar = document.getElementById("myBar");
      if (myBar) myBar.style.width = scrolled + "%";
    });
  }
  updateScrollProgress();

  function addHeadingLinks() {
    const article = document.getElementById("article");
    if (!article) return;
    const headings = Array.from(article.querySelectorAll("h2, h3, h4, h5, h6"));
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ml-2 opacity-0 group-hover:opacity-100 focus:opacity-100";
      link.href = "#" + heading.id;
      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  function attachCopyButtons() {
    const codeBlocks = Array.from(document.querySelectorAll("pre"));
    for (const codeBlock of codeBlocks) {
      let wrapper = codeBlock.parentElement;
      if (!wrapper || !wrapper.classList.contains("code-wrapper")) {
        wrapper = document.createElement("div");
        wrapper.className = "code-wrapper relative group";
        codeBlock.parentNode.insertBefore(wrapper, codeBlock);
        wrapper.appendChild(codeBlock);
      }
      const copyButton = document.createElement("button");
      copyButton.className = "copy-code";
      copyButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 10a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2z"/><path d="M16 8V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2"/></svg>`;
      copyButton.setAttribute("aria-label", "Copy code");
      wrapper.appendChild(copyButton);
      const code = codeBlock.querySelector("code");
      if (code) {
        const textContent = code.innerText.replace(/\n$/, "");
        const lineCount = textContent.split("\n").length;
        if (lineCount > 1) {
          const lineNumbers = document.createElement("div");
          lineNumbers.className = "line-numbers";
          lineNumbers.ariaHidden = "true";
          lineNumbers.innerHTML = Array.from(
            { length: lineCount },
            (_, i) => `<span>${i + 1}</span>`,
          ).join("");
          wrapper.appendChild(lineNumbers);
        }
      }
      codeBlock.setAttribute("tabindex", "0");
      copyButton.addEventListener("click", async () => {
        const code = codeBlock.querySelector("code");
        const text = code?.innerText;
        await navigator.clipboard.writeText(text ?? "");
        copyButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>`;
        setTimeout(() => {
          copyButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 10a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2z"/><path d="M16 8V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2"/></svg>`;
        }, 700);
      });
    }
  }
  attachCopyButtons();

  function hideTOCHeading() {
    const headings = document.querySelectorAll("h2");
    headings.forEach((heading) => {
      if (
        heading &&
        heading instanceof HTMLElement &&
        heading.textContent?.trim() === "Table of contents"
      ) {
        heading.style.display = "none";
      }
    });
  }
  hideTOCHeading();

  function mirrorSidebarQuotes() {
    const article = document.getElementById("article");
    const sidebar = document.getElementById("left-sidebar");
    const container = document.getElementById("sidebar-quotes");
    if (!article || !sidebar || !container) return;

    const previousSpoilerStates = Array.from(
      container.querySelectorAll('[data-component="spoiler"] input[type="checkbox"]'),
    ).map((input) => input.checked);
    let spoilerStateCursor = 0;

    container.innerHTML = "";

    const leftItems = Array.from(
      article.querySelectorAll('[data-position="left"]'),
    );
    if (leftItems.length === 0) return;

    const sidebarTop = sidebar.getBoundingClientRect().top + window.scrollY;

    leftItems.forEach((el) => {
      const elPageY = el.getBoundingClientRect().top + window.scrollY;
      const topPos = elPageY - sidebarTop;

      const mirror = document.createElement("div");
      mirror.style.cssText = `position:absolute;top:${topPos}px;left:0;right:0;display:flex;justify-content:center;`;

      const clone = el.cloneNode(true);
      if (clone instanceof HTMLElement) {
        clone.removeAttribute("data-position");
        const cloneSpoilerCount =
          (clone.matches?.('[data-component="spoiler"]') ? 1 : 0) +
          clone.querySelectorAll('[data-component="spoiler"]').length;
        if (cloneSpoilerCount > 0) {
          const cloneSpoilerInputs = clone.querySelectorAll(
            '[data-component="spoiler"] input[type="checkbox"]',
          );
          cloneSpoilerInputs.forEach((input, inputIndex) => {
            const prevState = previousSpoilerStates[spoilerStateCursor + inputIndex];
            if (typeof prevState === "boolean") {
              input.checked = prevState;
            }
          });
          spoilerStateCursor += cloneSpoilerInputs.length;
        }
        const ids = clone.querySelectorAll("[id]");
        ids.forEach((node) => {
          const oldId = node.id;
          const newId = oldId + "-sidebar";
          node.id = newId;
          const labels = clone.querySelectorAll(`label[for="${oldId}"]`);
          labels.forEach((l) => l.setAttribute("for", newId));
        });

        clone.style.width = "100%";
        clone.style.maxWidth = "260px";
        clone.classList.remove("my-8", "my-6", "my-4");
        clone.classList.add("my-0");

        if (clone.tagName === "FIGURE") {
          const blockquote = clone.querySelector("blockquote");
          if (blockquote) {
            blockquote.classList.replace("px-6", "px-4");
          }
        }
      }

      mirror.appendChild(clone);
      container.appendChild(mirror);
    });
  }
  mirrorSidebarQuotes();
  window.addEventListener("load", mirrorSidebarQuotes);

  function positionReadMore() {
    const article = document.getElementById("article");
    const readMore = document.getElementById("sidebar-readmore");
    const container = document.getElementById("sidebar-quotes");
    if (!article || !readMore) return;

    const articleHeight = article.offsetHeight || 0;
    const targetTop = articleHeight * 0.45;

    const mirrors = container ? Array.from(container.children) : [];
    let finalTop = targetTop;

    mirrors.forEach((m) => {
      if (!(m instanceof HTMLElement)) return;
      const mTop = parseFloat(m.style.top) || 0;
      const mBottom = mTop + m.offsetHeight;
      const readMoreHeight = readMore.offsetHeight || 300;

      const overlap =
        finalTop < mBottom + 30 && finalTop + readMoreHeight > mTop - 30;
      if (overlap) {
        finalTop = mBottom + 40;
      }
    });

    readMore.style.marginTop = finalTop + "px";
  }
  positionReadMore();
  window.addEventListener("load", positionReadMore);
  })();
</script>
