---
import { SITE } from "@config";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import Layout from "./Layout.astro";
import { TbBrandGithub, TbExternalLink } from "react-icons/tb";
import ClimbingBackToTop from "@components/ClimbingBackToTop.astro";
import { withBase } from "@utils/base";

export interface Project {
  title: string;
  description: string;
  techStack: string[];
  liveLink?: string;
  githubLink?: string;
  imageSrc?: string;
  imageSrcLight?: string;
  imageSrcDark?: string;
}

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
    projects: Project[];
  };
}

const { frontmatter } = Astro.props;
---

<Layout
  title={`${frontmatter.title} | ${SITE.title}`}
  description={frontmatter.description}
  ogImage="/projects/og.png"
>
  <Header activeNav="projects" />

  <main id="main-content" class="px-4 sm:px-6">
    {/* ===== HEADER ===== */}
    <section class="max-w-4xl mx-auto pt-24 sm:pt-20 pb-10">
      <div>
        <span
          class="font-mono text-[10px] uppercase tracking-widest text-skin-base/40 mb-4 block"
          >Things I've Built</span
        >
        <h1
          class="font-serif text-3xl sm:text-4xl text-skin-base leading-tight mb-3"
        >
          Projects
        </h1>
        <p class="text-sm text-skin-base/50 leading-relaxed max-w-lg">
          Open-source tools, research software, and side projects — from
          probabilistic programming to hackathon prototypes.
        </p>
      </div>
    </section>

    {/* ===== PROJECT LIST ===== */}
    <section class="max-w-4xl mx-auto pb-12">
      <div class="flex flex-col gap-5">
        {
          frontmatter.projects.map((project) => (
            <div>
              <article class="group flex flex-col sm:flex-row border border-skin-line/15 rounded-sm hover:border-skin-line/35 transition-all duration-300">
                <div class="sm:w-48 md:w-56 shrink-0 p-5 sm:p-6 flex items-center justify-center bg-skin-fill/20 border-b sm:border-b-0 sm:border-r border-skin-line/10">
                  {project.imageSrcLight && project.imageSrcDark ? (
                    <>
                      <img
                        src={withBase(project.imageSrcLight!)}
                        alt={project.title}
                        class="theme-image-light max-h-16 sm:max-h-20 object-contain"
                        loading="lazy"
                      />
                      <img
                        src={withBase(project.imageSrcDark!)}
                        alt={project.title}
                        class="theme-image-dark max-h-16 sm:max-h-20 object-contain"
                        loading="lazy"
                        style="display: none;"
                      />
                    </>
                  ) : (
                    <img
                      src={withBase(
                        project.imageSrc ||
                          project.imageSrcLight ||
                          project.imageSrcDark ||
                          "",
                      )}
                      alt={project.title}
                      class="max-h-16 sm:max-h-20 object-contain"
                      loading="lazy"
                    />
                  )}
                </div>

                <div class="flex-1 p-5 sm:p-6 flex flex-col justify-center min-w-0">
                  <div class="flex items-start justify-between gap-3 mb-1.5">
                    <h2 class="font-serif text-base font-bold text-skin-base group-hover:text-skin-accent transition-colors leading-snug">
                      {project.title}
                    </h2>
                    <div class="flex gap-2 shrink-0 mt-0.5">
                      {project.githubLink && (
                        <a
                          href={project.githubLink}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-skin-base/30 hover:text-skin-base transition-colors"
                          title="Source"
                        >
                          <TbBrandGithub className="w-4 h-4" />
                        </a>
                      )}
                      {project.liveLink && (
                        <a
                          href={project.liveLink}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-skin-base/30 hover:text-skin-base transition-colors"
                          title="Live"
                        >
                          <TbExternalLink className="w-4 h-4" />
                        </a>
                      )}
                    </div>
                  </div>

                  <p class="text-xs text-skin-base/50 leading-relaxed mb-3 line-clamp-2">
                    {project.description}
                  </p>

                  <div class="flex flex-wrap gap-1.5">
                    {project.techStack.map((tech: string) => (
                      <span class="inline-block px-2 py-0.5 text-[8px] font-mono uppercase tracking-wider border border-skin-line/15 text-skin-base/40 rounded-sm">
                        {tech}
                      </span>
                    ))}
                  </div>
                </div>
              </article>
            </div>
          ))
        }
      </div>
    </section>
  </main>
  <ClimbingBackToTop />
  <Footer />
</Layout>

<style>
  :global(html[data-theme="light"]) .theme-image-dark {
    display: none !important;
  }
  :global(html[data-theme="light"]) .theme-image-light {
    display: block !important;
  }

  :global(html[data-theme="dark"]) .theme-image-light {
    display: none !important;
  }
  :global(html[data-theme="dark"]) .theme-image-dark {
    display: block !important;
  }
</style>
