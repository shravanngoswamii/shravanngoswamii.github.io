---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Tag from "@components/Tag.astro";
import Datetime from "@components/Datetime";

import { slugifyStr } from "@utils/slugify";
import ShareLinks from "@components/ShareLinks.astro";
import Giscus from "@components/Giscus.astro";
import { SITE } from "@config";
import { getPublications, processLatex } from "@utils/bibtexUtils";
import { TbChevronLeft, TbChevronRight, TbBook } from "react-icons/tb";
import Tabs from "@components/Tabs.astro";
import TabItem from "@components/TabItem.astro";
import ClimbingBackToTop from "@components/ClimbingBackToTop.astro";
import TableOfContents from "@components/TableOfContents.astro";
import type { AnyPost, BlogCollection } from "../types";
import { COLLECTION_META } from "@utils/collections";
import Callout from "@components/mdx/Callout";
import QuoteBlock from "@components/mdx/QuoteBlock";
import Spoiler from "@components/mdx/Spoiler";
import Timeline from "@components/mdx/Timeline";
import Comparison, { ComparisonSide } from "@components/mdx/Comparison";
import Progress from "@components/mdx/Progress";

export interface Props {
  post: AnyPost;
  posts: AnyPost[];
  collection?: BlogCollection;
}

const { post, posts, collection = "tech" } = Astro.props;
const urlPrefix = COLLECTION_META[collection].prefix;

const {
  title,
  author,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  tags,
  toc = true,
} = post.data;

const director = 'director' in post.data ? (post.data as any).director : undefined;
const filmYear = 'year' in post.data ? (post.data as any).year : undefined;
const rating = 'rating' in post.data ? (post.data as any).rating : undefined;
const thinkers = 'thinkers' in post.data ? (post.data as any).thinkers as string[] | undefined : undefined;
const tradition = 'tradition' in post.data ? (post.data as any).tradition as string | undefined : undefined;

const publications = await getPublications();
const relatedPublications = publications.filter(pub => 
  pub.entryTags.keywords && tags.some(tag => pub.entryTags.keywords?.toLowerCase().includes(tag.toLowerCase()))
);

const { Content, headings } = await post.render();

// --- START: UPDATED OG IMAGE URL CONSTRUCTION ---
// If ogImage is explicitly set in frontmatter, use it.
// Otherwise, construct the path using the post.slug for the directory and 'og.png' for the filename.
const ogImageUrl = typeof ogImage === "string" ? ogImage : ogImage?.src;

const ogUrl = new URL(
  ogImageUrl ?? `${urlPrefix}/${post.slug}/og.png`,
  Astro.url.origin,
).href;
// --- END: UPDATED OG IMAGE URL CONSTRUCTION ---

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage: ogUrl,
  scrollSmooth: true,
};

/* ========== Prev/Next Posts ========== */

const allPosts = posts.map(({ data: { title }, slug }) => ({
  slug,
  title,
}));

const currentPostIndex = allPosts.findIndex((a) => a.slug === post.slug);

const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex !== allPosts.length ? allPosts[currentPostIndex + 1] : null;
---

<Layout {...layoutProps}>
  <Header />

  {/* ============ COLLECTION-THEMED HERO HEADER ============ */}
  {collection === "cinema" && (
    <div class="relative overflow-hidden border-b border-skin-line/10" style="background: linear-gradient(135deg, rgba(var(--color-collection-cinema), 0.06) 0%, transparent 60%)">
      <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: repeating-linear-gradient(90deg, transparent, transparent 40px, rgba(var(--color-collection-cinema), 0.5) 40px, rgba(var(--color-collection-cinema), 0.5) 41px); background-size: 41px 100%;"></div>
      <div class="mx-auto w-full max-w-screen-xl px-4 pt-36 sm:pt-32 pb-10">
        <div class="max-w-3xl mx-auto">
          <div class="mb-4 flex justify-start">
            <button class="focus-outline flex hover:opacity-75 items-center text-skin-base/60" onclick="(() => (history.length === 1) ? window.location = '/' : history.back())()">
              <TbChevronLeft className="inline-block h-5 w-5" /><span class="text-sm">Back</span>
            </button>
          </div>
          <div class="flex items-center gap-3 mb-5">
            <span class="px-2.5 py-1 rounded-sm text-[10px] font-mono uppercase tracking-widest font-medium" style="background: rgba(var(--color-collection-cinema), 0.12); color: rgb(var(--color-collection-cinema))">Cinema</span>
            {filmYear && <span class="font-mono text-sm text-skin-base/50">{filmYear}</span>}
          </div>
          <h1 transition:name={slugifyStr(title)} class="font-serif text-4xl sm:text-5xl leading-tight text-skin-base mb-4">{title}</h1>
          <p class="text-base text-skin-base/60 leading-relaxed max-w-2xl mb-6 font-sans">{description}</p>
          <div class="flex flex-wrap items-center gap-x-8 gap-y-3 py-4 border-t border-skin-line/15">
            {director && (
              <div class="flex flex-col">
                <span class="font-mono text-[9px] uppercase tracking-widest text-skin-base/35 mb-0.5">Directed by</span>
                <span class="text-base font-serif text-skin-base">{director}</span>
              </div>
            )}
            {rating !== undefined && (
              <div class="flex flex-col">
                <span class="font-mono text-[9px] uppercase tracking-widest text-skin-base/35 mb-0.5">Rating</span>
                <div class="flex items-baseline gap-1">
                  <span class="text-2xl font-serif font-medium" style="color: rgb(var(--color-collection-cinema))">{rating}</span>
                  <span class="text-sm text-skin-base/30 font-mono">/10</span>
                </div>
              </div>
            )}
            <div class="flex flex-col">
              <span class="font-mono text-[9px] uppercase tracking-widest text-skin-base/35 mb-0.5">Published</span>
              <Datetime pubDatetime={pubDatetime} modDatetime={modDatetime} size="lg" className="" />
            </div>
          </div>
        </div>
      </div>
    </div>
  )}

  {collection === "philosophy" && (
    <div class="relative overflow-hidden border-b border-skin-line/10" style="background: linear-gradient(180deg, rgba(var(--color-collection-philosophy), 0.05) 0%, transparent 70%)">

      <div class="mx-auto w-full max-w-screen-xl px-4 pt-36 sm:pt-32 pb-10">
        <div class="max-w-3xl mx-auto">
          <div class="mb-4 flex justify-start">
            <button class="focus-outline flex hover:opacity-75 items-center text-skin-base/60" onclick="(() => (history.length === 1) ? window.location = '/' : history.back())()">
              <TbChevronLeft className="inline-block h-5 w-5" /><span class="text-sm">Back</span>
            </button>
          </div>
          <div class="flex items-center gap-3 mb-5">
            <span class="px-2.5 py-1 rounded-sm text-[10px] font-mono uppercase tracking-widest font-medium" style="background: rgba(var(--color-collection-philosophy), 0.12); color: rgb(var(--color-collection-philosophy))">Philosophy</span>
            {tradition && <span class="font-serif text-sm italic text-skin-base/50">{tradition}</span>}
          </div>
          <h1 transition:name={slugifyStr(title)} class="font-serif text-4xl sm:text-5xl leading-tight text-skin-base mb-4">{title}</h1>
          <p class="text-base text-skin-base/60 leading-relaxed max-w-2xl font-serif italic mb-6">{description}</p>
          {thinkers && thinkers.length > 0 && (
            <div class="flex flex-wrap items-center gap-2 py-4 border-t border-skin-line/15">
              <span class="font-mono text-[9px] uppercase tracking-widest text-skin-base/35">In dialogue with</span>
              {thinkers.map((t) => (
                <span class="px-3 py-1 rounded-full text-xs font-serif border border-skin-line/20 text-skin-base/70" style="background: rgba(var(--color-collection-philosophy), 0.06)">{t}</span>
              ))}
            </div>
          )}
          <div class="flex items-center gap-4 mt-2">
            <Datetime pubDatetime={pubDatetime} modDatetime={modDatetime} size="lg" className="" />
          </div>
        </div>
      </div>
    </div>
  )}

  {collection === "tech" && (
    <div class="relative overflow-hidden border-b border-skin-line/10" style="background: linear-gradient(135deg, rgba(var(--color-collection-tech), 0.04) 0%, transparent 50%)">
      <div class="mx-auto w-full max-w-screen-xl px-4 pt-36 sm:pt-32 pb-10">
        <div class="max-w-3xl mx-auto">
          <div class="mb-4 flex justify-start">
            <button class="focus-outline flex hover:opacity-75 items-center text-skin-base/60" onclick="(() => (history.length === 1) ? window.location = '/' : history.back())()">
              <TbChevronLeft className="inline-block h-5 w-5" /><span class="text-sm">Back</span>
            </button>
          </div>
          <div class="flex items-center gap-3 mb-5">
            <span class="px-2.5 py-1 rounded-sm text-[10px] font-mono uppercase tracking-widest font-medium" style="background: rgba(var(--color-collection-tech), 0.12); color: rgb(var(--color-collection-tech))">Tech</span>
          </div>
          <h1 transition:name={slugifyStr(title)} class="font-serif text-3xl sm:text-4xl leading-tight text-skin-base mb-4">{title}</h1>
          <Datetime pubDatetime={pubDatetime} modDatetime={modDatetime} size="lg" className="my-2" />
        </div>
      </div>
    </div>
  )}

  {/* ============ MAIN CONTENT GRID ============ */}
  <div class="mx-auto w-full max-w-screen-xl px-4">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_minmax(auto,48rem)_1fr] gap-8">
      
      <!-- Left Column (Empty for centering) -->
      <div class="hidden lg:block"></div>

      <!-- Center Column (Content) -->
      <div class="flex flex-col">

        <main id="main-content">

          <!-- TOC Mobile (Inline) -->
          {toc && <TableOfContents headings={headings} mobile={true} />}

          <article id="article" class="prose mx-auto mt-8 max-w-3xl">
            <Content components={{ Tabs, TabItem, Callout, QuoteBlock, Spoiler, Timeline, Comparison, ComparisonSide, Progress }} />
          </article>

          {relatedPublications.length > 0 && (
            <div class="my-8 border-t border-skin-line/30 pt-8">
              <h3 class="text-xl font-bold text-skin-base mb-4">Associated Publications</h3>
              <ul class="space-y-4">
                {relatedPublications.map(pub => (
                  <li class="flex flex-col gap-1">
                    <div class="flex items-baseline gap-2">
                      <span class="text-skin-accent">
                        <TbBook className="h-4 w-4 inline-block" />
                      </span>
                      <div class="flex-1">
                        {pub.entryTags.url ? (
                          <a href={pub.entryTags.url} target="_blank" rel="noopener noreferrer" class="font-medium hover:underline decoration-dashed underline-offset-4">
                            <span set:html={processLatex(pub.entryTags.title)} />
                          </a>
                        ) : (
                          <span class="font-medium" set:html={processLatex(pub.entryTags.title)} />
                        )}
                        <span class="text-sm text-skin-base/60 ml-2">({pub.entryTags.year})</span>
                      </div>
                    </div>
                    <div class="text-sm text-skin-base/80 ml-6 italic">
                      {pub.entryTags.journal || pub.entryTags.booktitle || pub.entryTags.publisher || pub.entryTags.note}
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <ul class="my-8">
            {tags.map((tag) => <Tag tag={tag} />)}
          </ul>

          <div class="flex items-center justify-center">
            <ShareLinks />
          </div>

          <hr class="my-6 border-dashed" />

          <!-- Comments Section -->
          <Giscus />

          <!-- Previous/Next Post Buttons -->
          <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2">
            {
              prevPost && (
                <a
                  href={`${urlPrefix}/${prevPost.slug}`}
                  class="flex w-full gap-1 hover:opacity-75 items-center"
                >
                  <TbChevronLeft className="h-6 w-6 flex-none" />
                  <div>
                    <span>Previous Post</span>
                    <div class="text-sm text-skin-accent/85">{prevPost.title}</div>
                  </div>
                </a>
              )
            }
            {
              nextPost && (
                <a
                  href={`${urlPrefix}/${nextPost.slug}`}
                  class="flex w-full justify-end gap-1 text-right hover:opacity-75 sm:col-start-2 items-center"
                >
                  <div>
                    <span>Next Post</span>
                    <div class="text-sm text-skin-accent/85">{nextPost.title}</div>
                  </div>
                  <TbChevronRight className="h-6 w-6 flex-none" />
                </a>
              )
            }
          </div>
        </main>
      </div>

      <!-- Right Column (TOC Desktop) -->
      <aside class="hidden lg:block relative mt-40">
        {toc && (
          <div class="sticky top-24 transition-opacity duration-300">
            <TableOfContents headings={headings} />
          </div>
        )}
      </aside>

    </div>
  </div>
  
  <ClimbingBackToTop />
  
  <Footer />
</Layout>

<style>
  main {
    @apply w-full max-w-3xl pb-12 mx-auto lg:mx-0;
  }
  .post-title {
    @apply text-2xl font-semibold sm:text-3xl text-skin-base;
  }
  
  /* Ensure code blocks have proper theme-aware styling */
  :global(pre) {
    @apply rounded-lg border border-skin-line/20 overflow-x-auto;
    line-height: 1.5 !important; 
    font-size: 0.875rem !important; /* Base font size for container */
    padding: 1rem !important;
  }
  
  :global(pre code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace !important;
    font-size: 0.875rem !important; /* 14px */
    line-height: 1.5 !important; /* 21px */
    display: block; 
  }
  
  /* Shiki dual theme support */
  :global(.astro-code),
  :global(.astro-code span) {
    color: var(--shiki-light);
    background-color: transparent !important;
  }
  
  :global(html[data-theme="latte"] .astro-code),
  :global(html[data-theme="latte"] .astro-code span) {
    color: var(--shiki-light);
    background-color: transparent !important;
  }
  
  :global(html[data-theme="dark"] .astro-code),
  :global(html[data-theme="dark"] .astro-code span),
  :global(html[data-theme="frappe"] .astro-code),
  :global(html[data-theme="frappe"] .astro-code span),
  :global(html[data-theme="macchiato"] .astro-code),
  :global(html[data-theme="macchiato"] .astro-code span),
  :global(html[data-theme="mocha"] .astro-code),
  :global(html[data-theme="mocha"] .astro-code span) {
    color: var(--shiki-dark);
    background-color: transparent !important;
  }

  /* Glassy, Glowy, Premium Code Block Style */
  :global(pre) {
    @apply rounded-xl border border-skin-line/40 overflow-x-auto; /* Removed p-5 */
    background-color: rgba(var(--color-card), 0.6) !important; /* Semi-transparent base */
    backdrop-filter: blur(12px); /* Blur effect */
    box-shadow: 
      0 4px 6px -1px rgba(0, 0, 0, 0.1), 
      0 2px 4px -1px rgba(0, 0, 0, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.1); /* Subtle inner highlight */
    transition: all 0.3s ease;
  }

  :global(pre:hover) {
    box-shadow: 
      0 10px 15px -3px rgba(0, 0, 0, 0.1), 
      0 4px 6px -2px rgba(0, 0, 0, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
    border-color: rgba(var(--color-border), 0.6);
  }

  /* Copy Button Integration */
  :global(.copy-code) {
    @apply absolute right-2 top-2 z-20 p-1.5 opacity-0 transition-all scale-95 cursor-pointer;
    /* Removed background/border logic to match request "don't like bg and border" */
    /* Only icon visible */
    color: rgba(var(--color-text-base), 0.4); 
  }

  :global(.code-wrapper:hover .copy-code) {
    @apply opacity-100 scale-100;
  }

  :global(.copy-code:hover) {
    /* Slight glow/color on hover, but no box */
    color: rgba(var(--color-accent), 1); 
    filter: drop-shadow(0 0 4px rgba(var(--color-accent), 0.3));
  }
  
  /* Line Numbers Implementation - Minimal & Subtle */
  :global(.line-numbers) {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 2rem; 
    padding-top: 1rem; /* Match pre padding top exactly */
    padding-bottom: 1rem;
    text-align: right;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace !important;
    font-size: 0.875rem !important; /* 14px - Match code */
    line-height: 1.5 !important; /* 21px - Match code */
    color: rgba(var(--color-text-base), 0.25); 
    background-color: transparent; 
    user-select: none;
    pointer-events: none;
    overflow: hidden;
  }

  :global(pre) {
    /* padding handled in definition above */
    /* Remove padding entirely from code block container */
    padding-left: 2rem !important; 
    padding-right: 1rem !important;
    padding-top: 1rem !important;
    padding-bottom: 1rem !important;
  }
  
  :global(.line-numbers span) {
    display: block;
    padding-right: 0.75rem; /* Slight padding to separate from code */
    height: 1.3125rem; /* 14px * 1.5 = 21px (1.3125rem). Explicit height helps alignment */
  }

</style>

<script is:inline data-astro-rerun>
  /** Create a progress indicator
   * at the top */
  function createProgressBar() {
    // Create the main container div
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-skin-fill";

    // Create the progress bar div
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-skin-accent";
    progressBar.id = "myBar";

    // Append the progress bar to the progress container
    progressContainer.appendChild(progressBar);

    // Append the progress container to the document body or any other desired parent element
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  /** Update the progress bar
   * when user scrolls */
  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      if (document) {
        const myBar = document.getElementById("myBar");
        if (myBar) {
          myBar.style.width = scrolled + "%";
        }
      }
    });
  }
  updateScrollProgress();

  /** Attaches links to headings in the document,
   * allowing sharing of sections easily */
  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6"),
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ml-2 opacity-0 group-hover:opacity-100 focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  /** Attaches copy buttons to code blocks in the document,
   * allowing users to copy code easily. */
  function attachCopyButtons() {
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      // Create wrapper if not exists
      let wrapper = codeBlock.parentElement;
      if (!wrapper || !wrapper.classList.contains("code-wrapper")) {
        wrapper = document.createElement("div");
        wrapper.className = "code-wrapper relative group";
        codeBlock.parentNode.insertBefore(wrapper, codeBlock);
        wrapper.appendChild(codeBlock);
      }

      // Create Copy Button
      const copyButton = document.createElement("button");
      copyButton.className = "copy-code";
      copyButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-skin-base/60 hover:text-skin-accent transition-colors"><path d="M8 10a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2z"/><path d="M16 8V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2"/></svg>`;
      copyButton.setAttribute("aria-label", "Copy code");
      wrapper.appendChild(copyButton);

      // Add Line Numbers
      const code = codeBlock.querySelector("code");
      if (code) {
        // We need to count lines of the TEXT content, but handle potential empty last line from Prism/Shiki
        const textContent = code.innerText.replace(/\n$/, '');
        const lineCount = textContent.split('\n').length;
        
        if (lineCount > 1) { 
             const lineNumbers = document.createElement("div");
             lineNumbers.className = "line-numbers";
             lineNumbers.ariaHidden = "true";
             // Generate spans
             lineNumbers.innerHTML = Array.from({length: lineCount}, (_, i) => `<span>${i + 1}</span>`).join('');
             wrapper.appendChild(lineNumbers);
        }
      }

      codeBlock.setAttribute("tabindex", "0");

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      // visual feedback
      button.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-skin-accent"><path d="M20 6 9 17l-5-5"/></svg>`;
      
      setTimeout(() => {
        button.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-skin-base/60 hover:text-skin-accent transition-colors"><path d="M8 10a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2z"/><path d="M16 8V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2"/></svg>`;
      }, 700);
    }
  }
  attachCopyButtons();

  /* Go to page start after page swap */
  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" }),
  );

  /** Hide "Table of Contents" heading if it exists */
  function hideTOCHeading() {
    const headings = document.querySelectorAll("h2");
    headings.forEach((heading) => {
      if (heading.textContent.trim() === "Table of contents") {
        heading.style.display = "none";
      }
    });
  }
  hideTOCHeading();
</script>
