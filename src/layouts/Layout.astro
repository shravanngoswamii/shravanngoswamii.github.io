---
import { LOCALE, SITE } from "@config";
import "@styles/base.css";
import { ClientRouter } from "astro:transitions";
import { withBase } from "@utils/base";

const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;

export interface Props {
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
  loadKatex?: boolean;
}

const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  description = SITE.desc,
  ogImage = SITE.ogImage,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
  loadKatex = false,
} = Astro.props;

const socialImageURL = new URL(
  ogImage ?? SITE.ogImage ?? "og.png",
  SITE.website,
).href;

const isArticle = !!pubDatetime;

const structuredData = isArticle
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: title,
      description,
      image: socialImageURL,
      datePublished: pubDatetime!.toISOString(),
      ...(modDatetime && { dateModified: modDatetime.toISOString() }),
      mainEntityOfPage: { "@type": "WebPage", "@id": canonicalURL },
      author: [{ "@type": "Person", name: author, url: profile }],
      publisher: { "@type": "Person", name: SITE.author, url: SITE.website },
    }
  : {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: SITE.title,
      url: SITE.website,
      description: SITE.desc,
      author: [{ "@type": "Person", name: author, url: profile }],
    };
---

<!doctype html>
<html
  lang=`${LOCALE.lang ?? "en"}`
  class={`${scrollSmooth && "scroll-smooth"}`}
>
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function () {
        const docEl = document.documentElement;

        // On reload, disable smooth scrolling so the browser restores
        // scroll position instantly instead of visibly animating from top.
        if (docEl.classList.contains("scroll-smooth")) {
          docEl.style.scrollBehavior = "auto";
        }

        // Hide page until scroll position is restored to avoid
        // flashing the hero/top of the page on mid-page reloads.
        const nav = performance.getEntriesByType("navigation")[0];
        if (nav && nav.type === "reload") {
          docEl.classList.add("preload");
        }

        function release() {
          docEl.classList.remove("preload");
          if (docEl.classList.contains("scroll-smooth")) {
            docEl.style.scrollBehavior = "";
          }
        }

        window.addEventListener(
          "pageshow",
          function () { requestAnimationFrame(release); },
          { once: true },
        );
        document.addEventListener("astro:after-swap", release);
        document.addEventListener("astro:page-load", release);
      })();
    </script>

    <style is:inline>
      html.preload { opacity: 0; }

      /* Critical header styles — prevents FOUC before component CSS loads */
      #main-header, #mobile-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 40;
      }
      #mobile-header {
        z-index: 50;
        background-color: rgb(var(--color-fill) / 0.6);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
      }
    </style>

    <!-- Google tag (gtag.js) — deferred until idle to avoid blocking render -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(...args) { window.dataLayer.push(args); }
      gtag("js", new Date());
      gtag("config", "G-ZXC7NG6S55");

      (function () {
        function loadGA() {
          const s = document.createElement("script");
          s.src = "https://www.googletagmanager.com/gtag/js?id=G-ZXC7NG6S55";
          s.async = true;
          document.head.appendChild(s);
        }
        if ("requestIdleCallback" in window) {
          requestIdleCallback(loadGA);
        } else {
          setTimeout(loadGA, 3500);
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <link rel="sitemap" href={withBase("/sitemap-index.xml")} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={withBase("/rss.xml")}
    />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:type" content={isArticle ? "article" : "website"} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:locale" content={LOCALE.lang ?? "en"} />

    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />
    <meta name="twitter:site" content="@shravangoswamii" />
    <meta name="twitter:creator" content="@shravangoswamii" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
      is:inline
    />

    <!-- Self-hosted fonts — preload critical font files -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/playfair-display-latin.woff2" as="font" type="font/woff2" crossorigin />

    <meta name="theme-color" content="" />

    {
      googleSiteVerification && (
        <meta
          name="google-site-verification"
          content={googleSiteVerification}
        />
      )
    }

    <ClientRouter />

    <script is:inline>
      const primaryColorScheme = "";

      const currentTheme = localStorage.getItem("theme");

      function getPreferTheme() {
        if (currentTheme) return currentTheme;
        if (primaryColorScheme) return primaryColorScheme;
        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      }

      let themeValue = getPreferTheme();

      function reflectPreference(theme) {
        document.firstElementChild.setAttribute("data-theme", theme);

        const body = document.body;
        if (body) {
          const computedStyles = window.getComputedStyle(body);
          const bgColor = computedStyles.backgroundColor;
          document
            .querySelector("meta[name='theme-color']")
            ?.setAttribute("content", bgColor);
        }
      }

      reflectPreference(themeValue);

      document.addEventListener("astro:before-swap", (ev) => {
        const theme = localStorage.getItem("theme") || themeValue;
        ev.newDocument.firstElementChild.setAttribute("data-theme", theme);
      });

      document.addEventListener("astro:after-swap", () => {
        const theme = localStorage.getItem("theme") || themeValue;
        themeValue = theme;
        reflectPreference(theme);
      });

      window
        .matchMedia("(prefers-color-scheme: dark)")
        .addEventListener("change", ({ matches: isDark }) => {
          if (!localStorage.getItem("theme")) {
            themeValue = isDark ? "dark" : "light";
            reflectPreference(themeValue);
          }
        });
    </script>
    {loadKatex && (
      <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/katex@0.15.2/dist/katex.min.css"
      />
    )}
  </head>

  <body class="selection:bg-skin-accent selection:text-white">
    <div
      id="nav-progress"
      class="fixed top-0 left-0 h-0.5 z-9999 pointer-events-none"
      style="width: 0%; background: rgba(var(--color-accent), 1); transition: none; opacity: 0;"
    >
    </div>
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-MMG7M2PS"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <slot />

    <script is:inline>
      (function () {
        let bar = document.getElementById("nav-progress");
        let raf;
        let w = 0;

        function start() {
          if (!bar) bar = document.getElementById("nav-progress");
          if (!bar) return;
          cancelAnimationFrame(raf);
          w = 0;
          bar.style.transition = "none";
          bar.style.width = "0%";
          bar.style.opacity = "1";
          void bar.offsetWidth;
          tick();
        }

        function tick() {
          w += (90 - w) * 0.25;
          bar.style.transition = "none";
          bar.style.width = w + "%";
          if (w < 89.5) {
            raf = requestAnimationFrame(tick);
          }
        }

        function finish() {
          cancelAnimationFrame(raf);
          if (!bar) bar = document.getElementById("nav-progress");
          if (!bar) return;
          bar.style.transition = "width 0.15s ease-out";
          bar.style.width = "100%";
          setTimeout(function () {
            bar.style.transition = "opacity 0.3s ease";
            bar.style.opacity = "0";
          }, 150);
        }

        document.addEventListener("astro:before-preparation", start);
        document.addEventListener("astro:after-swap", finish);
        document.addEventListener("astro:page-load", function () {
          bar = document.getElementById("nav-progress");
        });
      })();
    </script>
  </body>
</html>
