---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import ClimbingBackToTop from "@components/ClimbingBackToTop.astro";
import ShelfCard from "@components/ShelfCard.astro";
import { withBase } from "@utils/base";
import {
  getAllPosts,
  COLLECTION_META,
  getPostUrl,
  getPostTopic,
} from "@utils/collections";
import getSortedPosts from "@utils/getSortedPosts";
import { stripExt } from "@utils/shelf";
import { getCollection } from "astro:content";

const resumePDF = withBase("/resume.pdf");
const embeddedResumePDF = `${resumePDF}#pagemode=none&zoom=page-fit&toolbar=0&navpanes=0`;

const recentPosts = getSortedPosts(await getAllPosts()).slice(0, 5);
const shelfRaw = await getCollection("shelf");
const shelfItems = shelfRaw
  .filter((i) => i.data.status === "done")
  .sort(() => Math.random() - 0.5)
  .slice(0, 6);
---

<Layout
  title={`Resume | ${SITE.title}`}
  description="Shravan Goswami's resume — education, experience, skills, and recent work."
  ogImage="/resume/og.png"
>
  <Header activeNav="resume" />

  <div
    class="mx-auto w-full max-w-7xl px-4 pt-28 sm:pt-24 pb-12 lg:max-w-none lg:px-0"
  >
    <div
      class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1fr)_40rem_minmax(0,1fr)] lg:gap-0"
    >
      {/* Left Column — Shelf Cards (desktop only) */}
      <aside class="hidden lg:flex lg:justify-center">
        <div class="sticky top-24 mt-32 w-60">
          <span
            class="block font-mono text-[9px] uppercase tracking-widest text-skin-base/30 mb-3"
            >Cool Things I See</span
          >
          <div class="grid grid-cols-2 gap-3">
            {
              shelfItems.map((item) => (
                <ShelfCard
                  type={item.data.type}
                  title={item.data.title}
                  creator={item.data.creator}
                  genre={item.data.genre}
                  status={item.data.status}
                  rating={item.data.rating}
                  poster={item.data.poster}
                  compact={true}
                  href={withBase(`/shelf/${stripExt(item.id)}/`)}
                />
              ))
            }
          </div>
        </div>
      </aside>
      <main id="main-content" class="flex flex-col items-center">
        <h1 class="text-2xl font-semibold text-skin-base mb-2">
          Shravan's Resume
        </h1>
        <LinkButton
          href={resumePDF}
          className="my-4 text-lg underline decoration-dashed underline-offset-8"
        >
          Download the PDF
        </LinkButton>
        <div class="w-full md:hidden">
          <div class="rounded-2xl border border-skin-line/40 bg-skin-fill/40 p-5 text-left backdrop-blur-sm">
            <p class="text-sm leading-7 text-skin-base/70">
              Embedded PDFs are unreliable on mobile browsers, so the resume opens
              as a regular PDF instead.
            </p>
            <div class="mt-4 flex flex-wrap gap-3">
              <a
                href={resumePDF}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center rounded-full border border-skin-accent/30 px-4 py-2 text-sm font-medium text-skin-accent transition-colors hover:border-skin-accent hover:text-skin-base"
              >
                Open the PDF
              </a>
              <a
                href={resumePDF}
                download
                class="inline-flex items-center rounded-full border border-skin-line/60 px-4 py-2 text-sm font-medium text-skin-base/80 transition-colors hover:border-skin-base/40 hover:text-skin-base"
              >
                Download it
              </a>
            </div>
          </div>
        </div>
        <div class="hidden w-full overflow-hidden rounded-lg md:block">
          <iframe
            src={embeddedResumePDF}
            class="block h-screen w-[calc(100%+18px)] border-none"
            style="margin-right: -18px;"
            title="My Resume"
          >
            This browser does not support PDFs. Please download the PDF to view it.
          </iframe>
        </div>
      </main>

      {/* Right Column — Recent Blogs (desktop only) */}
      <aside class="hidden lg:flex lg:justify-center">
        <div class="sticky top-24 mt-32 w-60">
          <span
            class="block font-mono text-[9px] uppercase tracking-widest text-skin-base/30 mb-3"
            >Recent Thoughts</span
          >
          <div class="flex flex-col gap-3">
            {
              recentPosts.map((p) => {
                const col = getPostTopic(p);
                return (
                  <a href={withBase(getPostUrl(p))} class="group block">
                    <div class="flex items-start gap-2">
                      <span
                        class="w-1 h-1 rounded-full mt-1.5 shrink-0"
                        style={`background: rgb(var(--color-collection-${col}))`}
                      />
                      <div class="flex flex-col">
                        <span class="text-xs text-skin-base/50 group-hover:text-skin-base transition-colors leading-snug line-clamp-2">
                          {p.data.title}
                        </span>
                        <span class="text-[9px] font-mono text-skin-base/25 mt-0.5">
                          {COLLECTION_META[col].label}
                        </span>
                      </div>
                    </div>
                  </a>
                );
              })
            }
          </div>
        </div>
      </aside>

      {/* Mobile: Shelf + Recent (stacked at bottom) */}
      <div class="lg:hidden mt-12 space-y-10">
        <div>
          <div class="flex items-center justify-between mb-3">
            <span
              class="font-mono text-[9px] uppercase tracking-widest text-skin-base/30"
              >Cool Things I See</span
            >
            <a
              href={withBase("/shelf/")}
              class="font-mono text-[9px] uppercase tracking-widest text-skin-base/30 hover:text-skin-base transition-colors"
              >Browse the shelf →</a
            >
          </div>
          <div
            class="flex gap-2 overflow-x-auto pb-2 snap-x snap-mandatory scrollbar-hide"
          >
            {
              shelfItems.map((item) => (
                <div class="shrink-0 w-30 snap-start">
                  <ShelfCard
                    type={item.data.type}
                    title={item.data.title}
                    creator={item.data.creator}
                    genre={item.data.genre}
                    status={item.data.status}
                    rating={item.data.rating}
                    poster={item.data.poster}
                    compact={true}
                    href={withBase(`/shelf/${stripExt(item.id)}/`)}
                  />
                </div>
              ))
            }
          </div>
        </div>
        <div>
          <span
            class="block font-mono text-[9px] uppercase tracking-widest text-skin-base/30 mb-4"
            >Recent Thoughts</span
          >
          <div class="flex flex-col gap-3">
            {
              recentPosts.map((p) => {
                const col = getPostTopic(p);
                return (
                  <a href={withBase(getPostUrl(p))} class="group block">
                    <div class="flex items-start gap-2">
                      <span
                        class="w-1.5 h-1.5 rounded-full mt-1 shrink-0"
                        style={`background: rgb(var(--color-collection-${col}))`}
                      />
                      <span class="text-sm text-skin-base/50 group-hover:text-skin-base transition-colors leading-snug">
                        {p.data.title}
                      </span>
                    </div>
                  </a>
                );
              })
            }
          </div>
        </div>
      </div>
    </div>

    <ClimbingBackToTop />
    <Footer />
  </div>

  <style>
    @media (max-width: 1000px) {
      iframe {
        width: 100% !important;
      }
    }
  </style>
</Layout>
