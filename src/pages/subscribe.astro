---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { SITE } from "@config";
---

<Layout title={`Subscribe — ${SITE.title}`} description="Subscribe to get notified when new posts are published.">
  <Header />
  <main id="main-content" class="flex flex-1 flex-col items-center px-4">
    <section class="w-full max-w-md py-20 sm:py-28">
      <div class="flex flex-col items-center gap-6 text-center">
        <h1 class="font-serif text-4xl sm:text-5xl italic text-skin-base tracking-tight">
          Stay in the loop
        </h1>
        <p class="text-sm text-skin-base/60 font-light max-w-sm leading-relaxed">
          I write about tech, cinema, philosophy, and the things that make us think.
          Subscribe to get a short email whenever something new goes live.
        </p>

        <div class="w-16 h-[1px] bg-skin-line/20 my-2"></div>

        <div class="w-full rounded-lg border border-skin-line/20 p-6 sm:p-8 bg-skin-card/30">
          <form id="subscribe-form" class="flex flex-col gap-4">
            <input
              type="email"
              name="email"
              placeholder="your@email.com"
              required
              class="w-full px-4 py-3 rounded text-sm font-mono bg-skin-fill border border-skin-line/40 text-skin-base placeholder:text-skin-base/30 focus:outline-none focus:border-skin-accent transition-colors"
            />
            <button
              type="submit"
              class="w-full py-3 rounded text-xs font-mono uppercase tracking-widest text-skin-accent bg-skin-accent/10 hover:bg-skin-accent/20 backdrop-blur-sm transition-all"
            >Subscribe</button>
          </form>
        </div>

        <p class="text-[10px] font-mono uppercase tracking-widest text-skin-base/30 mt-4">
          Free &middot; No spam &middot; Unsubscribe anytime
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  function initPageSubscribe() {
    const form = document.getElementById("subscribe-form") as HTMLFormElement | null;
    if (!form || form.dataset.bound) return;
    form.dataset.bound = "1";
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const email = new FormData(form).get("email") as string;
      if (!email) return;
      window.open(
        `https://shravangoswami.substack.com/subscribe?freeSignupEmail=${encodeURIComponent(email)}`,
        "_blank",
        "noopener"
      );
    });
  }
  initPageSubscribe();
  document.addEventListener("astro:after-swap", initPageSubscribe);
</script>
