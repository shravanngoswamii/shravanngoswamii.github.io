---
import { getCollection } from "astro:content";
import PostDetails from "@layouts/PostDetails.astro";
import getSortedPosts from "@utils/getSortedPosts";
import type { AnyPost } from "@types";
import { getPostSlug } from "@utils/collections";
export async function getStaticPaths() {
  const posts = await getCollection(
    "blog",
    ({ data }) => !data.draft && data.topic === "philosophy",
  );
  return posts.map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const allTopicPosts = await getCollection(
  "blog",
  ({ data }) => data.topic === "philosophy",
);
const sortedPosts = getSortedPosts(allTopicPosts as AnyPost[]);
---

<PostDetails post={post} posts={sortedPosts} />
