---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import ShelfCard from "@components/ShelfCard.astro";
import Card from "@components/Card";
import { SITE } from "@config";
import { getCollection } from "astro:content";
import getSortedPosts from "@utils/getSortedPosts";
import { COLLECTION_META, getPostUrl } from "@utils/collections";
import ClimbingBackToTop from "@components/ClimbingBackToTop.astro";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (() => {
  return [{ params: { page: undefined } }];
}) satisfies GetStaticPaths;

const posts = getSortedPosts(
  await getCollection("tech", ({ data }) => !data.draft)
);

const techShelf = (await getCollection("shelf"))
  .filter(i => i.data.categories.includes("tech"))
  .slice(0, 6);
---

<Layout title={`Tech | ${SITE.title}`}>
  <Header activeNav="blog" />

  <div class="relative overflow-hidden" style="background: linear-gradient(180deg, rgba(var(--color-collection-tech), 0.04) 0%, transparent 70%)">
    <div class="absolute top-6 right-10 font-mono text-[180px] leading-none select-none pointer-events-none opacity-[0.02]" style="color: rgb(var(--color-collection-tech))">λ</div>
    <div class="mx-auto w-full max-w-4xl px-4 sm:px-6 pt-36 sm:pt-32 pb-12">
      <div class="flex items-center gap-3 mb-6">
        <span class="px-2.5 py-1 rounded-sm text-[10px] font-mono uppercase tracking-widest font-medium" style="background: rgba(var(--color-collection-tech), 0.12); color: rgb(var(--color-collection-tech))">Tech</span>
        <span class="font-mono text-[10px] text-skin-base/30">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</span>
      </div>
      <h1 class="font-mono text-3xl sm:text-4xl text-skin-base leading-tight mb-4">
        Systems, Code & Ideas
      </h1>
      <p class="text-base text-skin-base/60 leading-relaxed max-w-xl">
        {COLLECTION_META.tech.description}
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-2">
        {Object.entries(COLLECTION_META).map(([key, m]) => (
          <a
            href={`${m.prefix}/`}
            class:list={[
              "rounded-full px-4 py-1.5 text-xs font-mono uppercase tracking-widest transition-all border",
              key === "tech"
                ? "border-transparent font-medium"
                : "border-skin-line/30 text-skin-base/60 hover:text-skin-base hover:bg-skin-card-muted",
            ]}
            style={key === "tech" ? `background: rgba(var(--color-collection-tech), 0.12); color: rgb(var(--color-collection-tech))` : ""}
          >
            {m.label}
          </a>
        ))}
        <a href="/blog/" class="rounded-full px-4 py-1.5 text-xs font-mono uppercase tracking-widest transition-all border border-skin-line/30 text-skin-base/60 hover:text-skin-base hover:bg-skin-card-muted">
          All
        </a>
      </div>
    </div>
  </div>

  <main id="main-content" class="mx-auto w-full max-w-4xl px-4 sm:px-6 pb-12 pt-8">
    <ul>
      {posts.map(post => (
        <Card href={getPostUrl(post)} frontmatter={post.data} />
      ))}
    </ul>
  </main>

  {techShelf.length > 0 && (
    <section class="mx-auto w-full max-w-4xl px-4 sm:px-6 pb-16">
      <div class="border-t border-skin-line/15 pt-10">
        <div class="flex items-end justify-between mb-8">
          <div>
            <span class="font-mono text-[10px] uppercase tracking-widest text-skin-base/35 block mb-1">Shelf</span>
            <h2 class="font-mono text-xl text-skin-base">From the Shelf</h2>
          </div>
          <a href="/shelf/" class="font-mono text-[10px] uppercase tracking-widest text-skin-base/40 hover:text-skin-base transition-colors border-b border-transparent hover:border-skin-base/30 pb-0.5">
            View all →
          </a>
        </div>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-3">
          {techShelf.map(item => (
            <ShelfCard
              type={item.data.type}
              title={item.data.title}
              creator={item.data.creator}
              genre={item.data.genre}
              status={item.data.status}
              rating={item.data.rating}
              year={item.data.year}
              compact
              href={`/shelf/${item.id}/`}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <ClimbingBackToTop />
  <Footer />
</Layout>
