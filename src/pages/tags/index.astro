---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import Tag from "@components/Tag.astro";
import getUniqueTags from "@utils/getUniqueTags";
import { SITE } from "@config";
import ClimbingBackToTop from "@components/ClimbingBackToTop.astro";
import { getAllPosts } from "@utils/collections";

const allPosts = await getAllPosts();

let tags = getUniqueTags(allPosts);
---

<Layout title={`Tags | ${SITE.title}`} ogImage="/tags/og.png">
  <Header activeNav="tags" />
  <Main pageTitle="Tags" pageDesc="All the tags used in posts.">
    <ul>
      {tags.map(({ tagName }) => <Tag tag={tagName} size="lg" />)}
    </ul>
  </Main>
  <ClimbingBackToTop />
  <Footer />
</Layout>
