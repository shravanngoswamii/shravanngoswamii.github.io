---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import ClimbingBackToTop from "@components/ClimbingBackToTop.astro";
import TableOfContents from "@components/TableOfContents.astro";
import ShareLinks from "@components/ShareLinks.astro";
import Giscus from "@components/Giscus.astro";
import { getCoverGradient, SHELF_STATUS, SHELF_TYPE } from "@utils/shelf";
import { SITE } from "@config";
import { TbChevronLeft, TbChevronRight } from "react-icons/tb";
import Tabs from "@components/Tabs.astro";
import TabItem from "@components/TabItem.astro";
import Callout from "@components/mdx/Callout";
import QuoteBlock from "@components/mdx/QuoteBlock";
import Spoiler from "@components/mdx/Spoiler";
import Timeline from "@components/mdx/Timeline";
import Comparison, { ComparisonSide } from "@components/mdx/Comparison";
import Progress from "@components/mdx/Progress";

export interface Props {
  entry: CollectionEntry<"shelf">;
  items: CollectionEntry<"shelf">[];
  index: number;
}

export async function getStaticPaths() {
  const items = await getCollection("shelf");
  return items.map((entry, index) => ({
    params: { slug: entry.id },
    props: { entry, items, index },
  }));
}

const { entry, items, index } = Astro.props;
const { data } = entry;
const { Content, headings } = await render(entry);
const gradient = getCoverGradient(data.title);
const statusInfo = SHELF_STATUS[data.status];
const typeInfo = SHELF_TYPE[data.type];
const hasContent = entry.body && entry.body.trim().length > 0;
const toc = headings.filter(h => h.depth > 1 && h.depth < 4);
const hasToc = toc.length > 0;

const isBook = data.type === "book";
const isFilm = ["movie", "documentary", "miniseries"].includes(data.type);
const isSeries = ["series", "sitcom"].includes(data.type);
const isAnime = data.type === "anime";
const isGame = data.type === "game";

const prevItem = index > 0 ? items[index - 1] : null;
const nextItem = index < items.length - 1 ? items[index + 1] : null;
---

<Layout title={`${data.title} | ${SITE.title}`} description={data.description} scrollSmooth>
  <Header />

  <div class="relative overflow-hidden border-b border-skin-line/10" style="background: linear-gradient(135deg, rgba(var(--color-text-base), 0.02) 0%, transparent 60%)">
    <div class="mx-auto w-full max-w-screen-xl px-4 pt-36 sm:pt-32 pb-10">
      <div class="max-w-3xl mx-auto">
        <div class="mb-4 flex justify-start">
          <button class="focus-outline flex hover:opacity-75 items-center text-skin-base/60" onclick="(() => (history.length === 1) ? window.location = '/shelf/' : history.back())()">
            <TbChevronLeft className="inline-block h-5 w-5" /><span class="text-sm">Back</span>
          </button>
        </div>

        <div class="flex flex-col sm:flex-row gap-8">
          <div class="w-32 sm:w-40 shrink-0">
            <div
              class="relative w-full aspect-[2/3] rounded overflow-hidden shadow-lg"
              style={`background: ${gradient}`}
            >
              <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 25% 15%, rgba(255,255,255,0.12) 0%, transparent 50%);"></div>
              {isBook && (
                <>
                  <div class="absolute left-0 inset-y-0 w-[3px] bg-black/25"></div>
                  <div class="absolute left-[3px] inset-y-0 w-[1px] bg-white/10"></div>
                </>
              )}
              {isFilm && (
                <div class="absolute inset-0 pointer-events-none opacity-[0.06]" style="background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(255,255,255,0.3) 3px, rgba(255,255,255,0.3) 4px);"></div>
              )}
              {isSeries && (
                <div class="absolute inset-0 pointer-events-none opacity-[0.04]" style="background: repeating-linear-gradient(90deg, transparent, transparent 8px, rgba(255,255,255,0.2) 8px, rgba(255,255,255,0.2) 9px);"></div>
              )}
              {isAnime && (
                <div class="absolute inset-0 pointer-events-none opacity-[0.05]" style="background: repeating-linear-gradient(45deg, transparent, transparent 5px, rgba(255,255,255,0.4) 5px, rgba(255,255,255,0.4) 6px);"></div>
              )}
              {isGame && (
                <div class="absolute inset-0 pointer-events-none opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;6&quot; height=&quot;6&quot; viewBox=&quot;0 0 6 6&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Crect width=&quot;3&quot; height=&quot;3&quot; fill=&quot;%23ffffff&quot;/%3E%3C/svg%3E'); background-size: 6px 6px;"></div>
              )}
              <div class="absolute inset-0 pointer-events-none opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;4&quot; height=&quot;4&quot; viewBox=&quot;0 0 4 4&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M1 3h1v1H1V3zm2-2h1v1H3V1z&quot; fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;/%3E%3C/svg%3E');"></div>
              <div class="absolute top-2 left-2 z-10">
                <span class="text-xs select-none">{typeInfo.icon}</span>
              </div>
              <div class="absolute inset-0 flex flex-col items-center justify-center px-3 text-center z-10">
                <h2 class="text-white font-serif text-xs sm:text-sm leading-snug drop-shadow-sm">{data.title}</h2>
              </div>
              <div class="absolute bottom-0 inset-x-0 z-10 bg-gradient-to-t from-black/60 via-black/20 to-transparent pt-8">
                <div class="text-center pb-2 px-2">
                  <p class="font-serif text-white/55 text-[10px] italic">{data.creator}</p>
                </div>
              </div>
            </div>
          </div>

          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-2 mb-4">
              <span class="px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider rounded-sm bg-skin-card-muted text-skin-base/60">
                {typeInfo.label}
              </span>
              {data.categories.map(cat => (
                <span
                  class="px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider rounded-sm"
                  style={`background: rgba(var(--color-collection-${cat}), 0.1); color: rgb(var(--color-collection-${cat}))`}
                >
                  {cat}
                </span>
              ))}
            </div>

            <h1 class="font-serif text-3xl sm:text-4xl text-skin-base leading-tight mb-2">
              {data.title}
            </h1>
            <p class="font-serif text-sm italic text-skin-base/50 mb-5">
              {data.creator}
            </p>

            <div class="flex flex-wrap items-center gap-x-8 gap-y-3 py-4 border-t border-skin-line/15">
              {data.rating !== undefined && (
                <div class="flex flex-col">
                  <span class="font-mono text-[9px] uppercase tracking-widest text-skin-base/35 mb-0.5">Rating</span>
                  <div class="flex items-baseline gap-1">
                    <span class="text-2xl font-serif font-medium text-skin-accent">{data.rating}</span>
                    <span class="text-sm text-skin-base/30 font-mono">/10</span>
                  </div>
                </div>
              )}
              <div class="flex flex-col">
                <span class="font-mono text-[9px] uppercase tracking-widest text-skin-base/35 mb-0.5">Status</span>
                <span
                  class="px-2 py-0.5 text-[10px] font-mono uppercase tracking-wider rounded-sm w-fit"
                  style={`background: ${statusInfo.color}20; color: ${statusInfo.color}`}
                >
                  {statusInfo.label}
                </span>
              </div>
              {data.year && (
                <div class="flex flex-col">
                  <span class="font-mono text-[9px] uppercase tracking-widest text-skin-base/35 mb-0.5">Year</span>
                  <span class="font-mono text-sm text-skin-base/70">{data.year}</span>
                </div>
              )}
              {data.genre && (
                <div class="flex flex-col">
                  <span class="font-mono text-[9px] uppercase tracking-widest text-skin-base/35 mb-0.5">Genre</span>
                  <span class="font-serif text-sm italic text-skin-base/60">{data.genre}</span>
                </div>
              )}
            </div>

            {data.description && (
              <p class="text-sm text-skin-base/60 leading-relaxed mt-3">
                {data.description}
              </p>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto w-full max-w-screen-xl px-4">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_minmax(auto,48rem)_1fr] gap-8">
      <div class="hidden lg:block"></div>

      <div class="flex flex-col">
        <main id="main-content">
          {hasToc && <TableOfContents headings={headings} mobile={true} open={true} />}

          {hasContent && (
            <article id="article" class="prose mx-auto mt-8 max-w-3xl">
              <Content components={{ Tabs, TabItem, Callout, QuoteBlock, Spoiler, Timeline, Comparison, ComparisonSide, Progress }} />
            </article>
          )}

          {!hasContent && (
            <div class="mx-auto mt-12 max-w-3xl text-center py-16">
              <p class="text-skin-base/30 font-mono text-sm">No notes yet — check back later.</p>
            </div>
          )}

          <div class="flex items-center justify-center mt-8">
            <ShareLinks />
          </div>

          <hr class="my-6 border-dashed" />

          <Giscus />

          <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2">
            {prevItem && (
              <a
                href={`/shelf/${prevItem.id}/`}
                class="flex w-full gap-1 hover:opacity-75 items-center"
              >
                <TbChevronLeft className="h-6 w-6 flex-none" />
                <div>
                  <span>Previous</span>
                  <div class="text-sm text-skin-accent/85">{prevItem.data.title}</div>
                </div>
              </a>
            )}
            {nextItem && (
              <a
                href={`/shelf/${nextItem.id}/`}
                class="flex w-full justify-end gap-1 text-right hover:opacity-75 sm:col-start-2 items-center"
              >
                <div>
                  <span>Next</span>
                  <div class="text-sm text-skin-accent/85">{nextItem.data.title}</div>
                </div>
                <TbChevronRight className="h-6 w-6 flex-none" />
              </a>
            )}
          </div>
        </main>
      </div>

      <aside class="hidden lg:block relative mt-8">
        {hasToc && (
          <div class="sticky top-24 transition-opacity duration-300">
            <TableOfContents headings={headings} />
          </div>
        )}
      </aside>
    </div>
  </div>

  <ClimbingBackToTop />
  <Footer />
</Layout>

<style>
  main {
    @apply w-full max-w-3xl pb-12 mx-auto lg:mx-0;
  }

  :global(pre) {
    @apply rounded-lg border border-skin-line/20 overflow-x-auto;
    line-height: 1.5 !important;
    font-size: 0.875rem !important;
    padding: 1rem !important;
  }

  :global(pre code) {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace !important;
    font-size: 0.875rem !important;
    line-height: 1.5 !important;
    display: block;
  }

  :global(.astro-code),
  :global(.astro-code span) {
    color: var(--shiki-light);
    background-color: transparent !important;
  }

  :global(html[data-theme="dark"] .astro-code),
  :global(html[data-theme="dark"] .astro-code span),
  :global(html[data-theme="frappe"] .astro-code),
  :global(html[data-theme="frappe"] .astro-code span),
  :global(html[data-theme="macchiato"] .astro-code),
  :global(html[data-theme="macchiato"] .astro-code span),
  :global(html[data-theme="mocha"] .astro-code),
  :global(html[data-theme="mocha"] .astro-code span) {
    color: var(--shiki-dark);
    background-color: transparent !important;
  }

  :global(pre) {
    background-color: rgba(var(--color-card), 0.6) !important;
    backdrop-filter: blur(12px);
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.1),
      0 2px 4px -1px rgba(0, 0, 0, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
    transition: all 0.3s ease;
  }

  :global(pre:hover) {
    box-shadow:
      0 10px 15px -3px rgba(0, 0, 0, 0.1),
      0 4px 6px -2px rgba(0, 0, 0, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
    border-color: rgba(var(--color-border), 0.6);
  }

  :global(.copy-code) {
    @apply absolute right-2 top-2 z-20 p-1.5 opacity-0 transition-all scale-95 cursor-pointer;
    color: rgba(var(--color-text-base), 0.4);
  }
  :global(.code-wrapper:hover .copy-code) {
    @apply opacity-100 scale-100;
  }
  :global(.copy-code:hover) {
    color: rgba(var(--color-accent), 1);
    filter: drop-shadow(0 0 4px rgba(var(--color-accent), 0.3));
  }

  :global(.line-numbers) {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 2rem;
    padding-top: 1rem;
    padding-bottom: 1rem;
    text-align: right;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace !important;
    font-size: 0.875rem !important;
    line-height: 1.5 !important;
    color: rgba(var(--color-text-base), 0.25);
    user-select: none;
    pointer-events: none;
    overflow: hidden;
  }

  :global(pre) {
    padding-left: 2rem !important;
    padding-right: 1rem !important;
    padding-top: 1rem !important;
    padding-bottom: 1rem !important;
  }

  :global(.line-numbers span) {
    display: block;
    padding-right: 0.75rem;
    height: 1.3125rem;
  }
</style>

<script is:inline data-astro-rerun>
  function createProgressBar() {
    const progressContainer = document.createElement("div");
    progressContainer.className = "progress-container fixed top-0 z-10 h-1 w-full bg-skin-fill";
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-skin-accent";
    progressBar.id = "myBar";
    progressContainer.appendChild(progressBar);
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      const myBar = document.getElementById("myBar");
      if (myBar) myBar.style.width = scrolled + "%";
    });
  }
  updateScrollProgress();

  function addHeadingLinks() {
    const headings = Array.from(document.querySelectorAll("h2, h3, h4, h5, h6"));
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className = "heading-link ml-2 opacity-0 group-hover:opacity-100 focus:opacity-100";
      link.href = "#" + heading.id;
      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  function attachCopyButtons() {
    const codeBlocks = Array.from(document.querySelectorAll("pre"));
    for (const codeBlock of codeBlocks) {
      let wrapper = codeBlock.parentElement;
      if (!wrapper || !wrapper.classList.contains("code-wrapper")) {
        wrapper = document.createElement("div");
        wrapper.className = "code-wrapper relative group";
        codeBlock.parentNode.insertBefore(wrapper, codeBlock);
        wrapper.appendChild(codeBlock);
      }
      const copyButton = document.createElement("button");
      copyButton.className = "copy-code";
      copyButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 10a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2z"/><path d="M16 8V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2"/></svg>`;
      copyButton.setAttribute("aria-label", "Copy code");
      wrapper.appendChild(copyButton);
      const code = codeBlock.querySelector("code");
      if (code) {
        const textContent = code.innerText.replace(/\n$/, '');
        const lineCount = textContent.split('\n').length;
        if (lineCount > 1) {
          const lineNumbers = document.createElement("div");
          lineNumbers.className = "line-numbers";
          lineNumbers.ariaHidden = "true";
          lineNumbers.innerHTML = Array.from({length: lineCount}, (_, i) => `<span>${i + 1}</span>`).join('');
          wrapper.appendChild(lineNumbers);
        }
      }
      codeBlock.setAttribute("tabindex", "0");
      copyButton.addEventListener("click", async () => {
        const code = codeBlock.querySelector("code");
        const text = code?.innerText;
        await navigator.clipboard.writeText(text ?? "");
        copyButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>`;
        setTimeout(() => {
          copyButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 10a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-8a2 2 0 0 1-2-2z"/><path d="M16 8V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2"/></svg>`;
        }, 700);
      });
    }
  }
  attachCopyButtons();

  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" }),
  );

  function hideTOCHeading() {
    const headings = document.querySelectorAll("h2");
    headings.forEach((heading) => {
      if (heading.textContent.trim() === "Table of contents") {
        heading.style.display = "none";
      }
    });
  }
  hideTOCHeading();
</script>
