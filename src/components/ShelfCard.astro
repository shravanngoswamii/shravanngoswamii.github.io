---
import { getCoverGradient, SHELF_STATUS, SHELF_TYPE, type ShelfType } from "@utils/shelf";

export interface Props {
  type: ShelfType;
  title: string;
  creator: string;
  genre: string;
  status: string;
  rating?: number;
  year?: number;
  description?: string;
  compact?: boolean;
  href?: string;
}

const {
  type,
  title,
  creator,
  genre,
  status,
  rating,
  year,
  description,
  compact = false,
  href,
} = Astro.props;

const gradient = getCoverGradient(title);
const statusInfo = SHELF_STATUS[status as keyof typeof SHELF_STATUS];
const typeInfo = SHELF_TYPE[type];
const Tag = href ? "a" : "div";

const isBook = type === "book";
const isFilm = ["movie", "documentary", "miniseries"].includes(type);
const isSeries = ["series", "sitcom"].includes(type);
const isAnime = type === "anime";
const isGame = type === "game";
const isCourse = type === "course";
const isVideo = type === "video";
---

<Tag
  class:list={["shelf-card group block", compact ? "" : "flex flex-col gap-3"]}
  data-status={status}
  data-type={type}
  {...(href ? { href } : {})}
>
  <div
    class:list={[
      "shelf-cover relative w-full aspect-[2/3] rounded overflow-hidden shadow-md transition-all duration-300",
      "group-hover:shadow-xl group-hover:-translate-y-1",
    ]}
    style={`background: ${gradient}`}
  >
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 25% 15%, rgba(255,255,255,0.12) 0%, transparent 50%);"></div>

    {isBook && (
      <>
        <div class="absolute left-0 inset-y-0 w-[3px] bg-black/25"></div>
        <div class="absolute left-[3px] inset-y-0 w-[1px] bg-white/10"></div>
      </>
    )}

    {isFilm && (
      <div class="absolute inset-0 pointer-events-none opacity-[0.06]" style="background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(255,255,255,0.3) 3px, rgba(255,255,255,0.3) 4px);"></div>
    )}

    {isSeries && (
      <>
        <div class="absolute left-0 inset-y-0 w-[2px] bg-white/10"></div>
        <div class="absolute right-0 inset-y-0 w-[2px] bg-white/10"></div>
        <div class="absolute inset-0 pointer-events-none opacity-[0.04]" style="background: repeating-linear-gradient(90deg, transparent, transparent 8px, rgba(255,255,255,0.2) 8px, rgba(255,255,255,0.2) 9px);"></div>
      </>
    )}

    {isAnime && (
      <div class="absolute inset-0 pointer-events-none opacity-[0.05]" style="background: repeating-linear-gradient(45deg, transparent, transparent 5px, rgba(255,255,255,0.4) 5px, rgba(255,255,255,0.4) 6px);"></div>
    )}

    {isGame && (
      <div class="absolute inset-0 pointer-events-none opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;6&quot; height=&quot;6&quot; viewBox=&quot;0 0 6 6&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Crect width=&quot;3&quot; height=&quot;3&quot; fill=&quot;%23ffffff&quot;/%3E%3C/svg%3E'); background-size: 6px 6px;"></div>
    )}

    {isCourse && (
      <div class="absolute inset-0 pointer-events-none opacity-[0.05]" style="background: repeating-linear-gradient(0deg, transparent, transparent 12px, rgba(255,255,255,0.3) 12px, rgba(255,255,255,0.3) 13px), repeating-linear-gradient(90deg, transparent, transparent 12px, rgba(255,255,255,0.15) 12px, rgba(255,255,255,0.15) 13px);"></div>
    )}

    {isVideo && !compact && (
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-[0.08]">
        <svg class="w-16 h-16" viewBox="0 0 24 24" fill="white"><polygon points="5,3 19,12 5,21"/></svg>
      </div>
    )}

    <div class="absolute inset-0 pointer-events-none opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;4&quot; height=&quot;4&quot; viewBox=&quot;0 0 4 4&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M1 3h1v1H1V3zm2-2h1v1H3V1z&quot; fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;/%3E%3C/svg%3E');"></div>

    {!compact && (
      <div class="absolute top-2.5 right-2.5 z-10">
        <span
          class="px-1.5 py-0.5 text-[8px] font-mono uppercase tracking-wider rounded-sm"
          style={`background: rgba(0,0,0,0.45); backdrop-filter: blur(4px); color: ${statusInfo.color}`}
        >
          {statusInfo.label}
        </span>
      </div>
    )}

    <div class:list={["absolute z-10", compact ? "top-1.5 left-1.5" : "top-2.5 left-2.5"]}>
      <span class:list={["select-none", compact ? "text-[10px]" : "text-xs"]}>{typeInfo.icon}</span>
    </div>

    <div class="absolute inset-0 flex flex-col items-center justify-center px-3 text-center z-10">
      <h3 class:list={["text-white font-serif leading-snug drop-shadow-sm", compact ? "text-[10px] sm:text-[11px]" : "text-sm sm:text-base"]}>
        {title}
      </h3>
      {!compact && (
        <p class="font-mono text-[7px] uppercase tracking-widest text-white/25 mt-1.5">{genre}</p>
      )}
    </div>

    <div class="absolute bottom-0 inset-x-0 z-10 bg-gradient-to-t from-black/60 via-black/20 to-transparent pt-8">
      {compact ? (
        <div class="flex items-end justify-between pb-1.5 px-1.5 gap-1">
          <p class="font-serif text-white/50 text-[8px] truncate italic">{creator}</p>
          {rating !== undefined && (
            <span class="font-mono font-medium text-[7px] shrink-0 text-white/50">
              {rating}<span class="text-white/25">/10</span>
            </span>
          )}
        </div>
      ) : (
        <div class="text-center pb-3 px-3">
          <p class="font-serif text-white/55 text-[11px] italic">{creator}</p>
          {year && (
            <p class="text-white/25 text-[9px] font-mono mt-0.5">{year}</p>
          )}
        </div>
      )}
    </div>

    {!compact && rating !== undefined && (
      <div class="absolute z-10 bottom-2 right-2.5">
        <span
          class="font-mono font-medium text-[10px] backdrop-blur-sm rounded-sm px-1 py-0.5"
          style="background: rgba(0,0,0,0.4); color: rgba(255,255,255,0.7);"
        >
          {rating}<span class="text-white/30">/10</span>
        </span>
      </div>
    )}
  </div>

  {!compact && description && (
    <p class="text-[11px] text-skin-base/40 leading-relaxed line-clamp-2 px-0.5">
      {description}
    </p>
  )}
</Tag>
