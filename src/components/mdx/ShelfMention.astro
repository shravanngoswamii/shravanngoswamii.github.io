---
import { getCollection } from "astro:content";
import { getCoverGradient, SHELF_TYPE, stripExt } from "@utils/shelf";

export interface Props {
  id: string;
}

const { id } = Astro.props;
const allShelf = await getCollection("shelf");
const item = allShelf.find((i) => stripExt(i.id) === id);
---

{
  item ? (
    <span class="shelf-mention">
      <a href={`/shelf/${stripExt(item.id)}/`} class="shelf-mention-link">
        <slot />
      </a>
      <span class="shelf-mention-card" aria-hidden="true">
        <span
          class="shelf-mention-cover"
          style={`background: ${getCoverGradient(item.data.title)}`}
        >
          {item.data.poster && (
            <img
              src={item.data.poster}
              alt=""
              class="shelf-mention-cover-poster"
              loading="lazy"
            />
          )}
          <span
            class="shelf-mention-cover-icon"
            set:html={SHELF_TYPE[item.data.type].icon}
          />
          <span class="shelf-mention-cover-text">
            <span class="shelf-mention-cover-title">{item.data.title}</span>
            <span class="shelf-mention-cover-creator">{item.data.creator}</span>
          </span>
        </span>
        <span class="shelf-mention-info">
          <span class="shelf-mention-title">{item.data.title}</span>
          <span class="shelf-mention-meta">
            <span>{item.data.creator}</span>
            {item.data.year && <span>· {item.data.year}</span>}
          </span>
          {item.data.rating !== undefined && (
            <span class="shelf-mention-rating">
              {item.data.rating}
              <span class="shelf-mention-rating-dim">/10</span>
            </span>
          )}
          {item.data.description && (
            <span class="shelf-mention-desc">{item.data.description}</span>
          )}
          <span class="shelf-mention-type">
            {SHELF_TYPE[item.data.type].label}
          </span>
        </span>
      </span>
    </span>
  ) : (
    <slot />
  )
}

<style>
  .shelf-mention {
    position: relative;
    display: inline;
  }

  .shelf-mention-link {
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 3px;
    text-decoration-color: rgb(var(--color-accent));
    color: rgb(var(--color-accent));
    cursor: pointer;
    transition: text-decoration-color 0.15s;
  }

  .shelf-mention-link:hover {
    text-decoration-style: solid;
  }

  .shelf-mention-card {
    display: none;
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    width: 14rem;
    border-radius: 8px;
    overflow: hidden;
    box-shadow:
      0 8px 30px rgba(0, 0, 0, 0.18),
      0 2px 8px rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(var(--color-border), 0.25);
    background: rgba(var(--color-fill), 0.98);
    backdrop-filter: blur(16px);
    z-index: 50;
    pointer-events: none;
    flex-direction: column;
  }

  .shelf-mention:hover .shelf-mention-card {
    display: flex;
  }

  .shelf-mention-card::after {
    content: "";
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 12px;
    height: 12px;
    background: rgba(var(--color-fill), 0.98);
    border-right: 1px solid rgba(var(--color-border), 0.25);
    border-bottom: 1px solid rgba(var(--color-border), 0.25);
    z-index: -1;
  }

  .shelf-mention-cover {
    display: block;
    width: 100%;
    height: 5rem;
    position: relative;
    overflow: hidden;
  }

  .shelf-mention-cover-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .shelf-mention-cover-icon {
    position: absolute;
    top: 4px;
    left: 6px;
    width: 10px;
    height: 10px;
    color: white;
    z-index: 2;
    display: inline-flex;
  }
  .shelf-mention-cover-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .shelf-mention-cover-text {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.375rem 0.5rem;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
    z-index: 2;
  }

  .shelf-mention-cover-title {
    display: block;
    color: white;
    font-family: var(--font-serif, Georgia, serif);
    font-size: 0.625rem;
    line-height: 1.3;
  }

  .shelf-mention-cover-creator {
    display: block;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.5rem;
    font-style: italic;
    margin-top: 1px;
  }

  .shelf-mention-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 0.5rem;
  }

  .shelf-mention-title {
    font-family: var(--font-serif, Georgia, serif);
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(var(--color-text-base), 0.85);
    line-height: 1.3;
  }

  .shelf-mention-meta {
    display: flex;
    gap: 0.25rem;
    font-size: 0.625rem;
    color: rgba(var(--color-text-base), 0.45);
  }

  .shelf-mention-rating {
    font-family: ui-monospace, monospace;
    font-size: 0.6875rem;
    color: rgb(var(--color-accent));
  }

  .shelf-mention-rating-dim {
    color: rgba(var(--color-text-base), 0.25);
    font-size: 0.5625rem;
  }

  .shelf-mention-desc {
    font-size: 0.5625rem;
    line-height: 1.4;
    color: rgba(var(--color-text-base), 0.4);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .shelf-mention-type {
    font-family: ui-monospace, monospace;
    font-size: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(var(--color-text-base), 0.3);
    margin-top: 2px;
  }
</style>
